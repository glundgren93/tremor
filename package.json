{
  "name": "tremor",
  "version": "0.3.0",
  "private": true,
  "description": "Chaos engineering dashboard for testing frontend resilience",
  "type": "module",
  "scripts": {
    "build": "tsdown && vite build",
    "dev": "tsdown && (node dist/server.mjs & VITE_WS_HOST=localhost:3000 vite)",
    "dev:ui": "vite",
    "dashboard": "node dist/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.56",
    "playwright": "^1.58.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "4.5.2",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vite": "6.3.5",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "playwright"
    ]
  }
}
